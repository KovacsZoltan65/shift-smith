			identifier: missingType.generics
			count: 1
			path: app/Models/WorkShift.php

		-
			message: '#^Class App\\Models\\WorkShiftAssignment uses generic trait Illuminate\\Database\\Eloquent\\Factories\\HasFactory but does not specify its types\: TFactory$#'
			identifier: missingType.generics
			count: 1
			path: app/Models/WorkShiftAssignment.php

		-
			message: '#^Method App\\Models\\WorkShiftAssignment\:\:company\(\) return type with generic class Illuminate\\Database\\Eloquent\\Relations\\BelongsTo does not specify its types\: TRelatedModel, TDeclaringModel$#'
			identifier: missingType.generics
			count: 1
