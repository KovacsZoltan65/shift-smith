parameters:
	ignoreErrors:
		-
			message: '#^Parameter \#1 \$data of method App\\Services\\WorkScheduleService\:\:store\(\) expects array\{company_id\: int, name\: string, date_from\: string, date_to\: string, status\: string, notes\?\: string\|null\}, array\<string, mixed\> given\.$#'
			identifier: argument.type
			count: 1
			path: app/Http/Controllers/WorkScheduleController.php

		-
			message: '#^Parameter \#1 \$data of method App\\Services\\WorkScheduleService\:\:update\(\) expects array\{company_id\: int, name\: string, date_from\: string, date_to\: string, status\: string, notes\?\: string\|null\}, array\<string, mixed\> given\.$#'
			identifier: argument.type
			count: 1
			path: app/Http/Controllers/WorkScheduleController.php

		-
			message: '#^Method App\\Interfaces\\Admin\\PermissionRepositoryInterface\:\:destroyBulk\(\) has parameter \$ids with no value type specified in iterable type array\.$#'
