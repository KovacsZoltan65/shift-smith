			identifier: missingType.generics
			count: 1
			path: app/Models/WorkShiftAssignment.php

		-
			message: '#^PHPDoc type array\<int, string\> of property App\\Models\\WorkShiftAssignment\:\:\$fillable is not covariant with PHPDoc type list\<string\> of overridden property Illuminate\\Database\\Eloquent\\Model\:\:\$fillable\.$#'
			identifier: property.phpDocType
			count: 1
			path: app/Models/WorkShiftAssignment.php

		-
			message: '#^Called ''env'' outside of the config directory which returns null when the config is cached, use ''config''\.$#'
			identifier: larastan.noEnvCallsOutsideOfConfig
			count: 1
