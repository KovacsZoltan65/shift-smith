		-
			message: '#^Using nullsafe property access "\?\-\>company_id" on left side of \?\? is unnecessary\. Use \-\> instead\.$#'
			identifier: nullsafe.neverNull
			count: 1
			path: app/Repositories/WorkScheduleRepository.php

		-
			message: '#^Relation ''companies'' is not found in App\\Models\\Company model\.$#'
			identifier: larastan.relationExistence
			count: 1
			path: app/Repositories/WorkShiftRepository.php

