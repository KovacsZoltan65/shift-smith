			count: 1
			path: app/Interfaces/Admin/PermissionRepositoryInterface.php

		-
			message: '#^Method App\\Interfaces\\Admin\\RoleRepositoryInterface\:\:bulkDelete\(\) has parameter \$ids with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: app/Interfaces/Admin/RoleRepositoryInterface.php

		-
			message: '#^Method App\\Interfaces\\WorkScheduleRepositoryInterface\:\:store\(\) has parameter \$data with no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
